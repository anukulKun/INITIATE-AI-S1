# ── Deployer wallet ───────────────────────────────────────────────
# Export your wallet's private key from MetaMask or cast wallet
# NEVER commit the real .env to git
DEPLOYER_PRIVATE_KEY=0x_your_private_key_here

# ── Initia testnet ────────────────────────────────────────────────
# Get from: https://docs.initia.xyz/build-on-initia/evm/networks
INITIA_RPC_URL=https://rpc.testnet.initia.xyz
INITIA_CHAIN_ID=

# ── Your custom Initia appchain ───────────────────────────────────
# Fill these after you deploy your appchain via Initia CLI
APPCHAIN_RPC_URL=http://localhost:8545
APPCHAIN_CHAIN_ID=
APPCHAIN_EXPLORER_API=http://localhost:4000/api
APPCHAIN_EXPLORER_URL=http://localhost:4000
